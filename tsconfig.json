{
	"compilerOptions": {
		"noImplicitAny": true,
		"moduleResolution": "bundler",
		"module": "esnext",
		"target": "es6",
		"allowJs": false,
		"strict": true,
		"sourceMap": true,
		"outDir": "./dist/",
		"declaration": true,
		"typeRoots": ["node_modules/@types"],
		"allowSyntheticDefaultImports": true,
		"noEmit": true,
		"skipLibCheck": true,
	},
	"include": [
		"src",
		"test"
	],
	"ts-node": {
		"compilerOptions": {
			"module": "esnext",
			"moduleResolution": "bundler",
		}
	}
}
